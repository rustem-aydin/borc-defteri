{
  "expo": {
    "name": "Akıllı Kaza Namazı Rehberi",
    "slug": "borc-defteri",
    "scheme": "akillikazanamazirehberi",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",

    "build": {
      "production": {
        "android": {
          "buildType": "app-bundle"
        }
      }
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f7faf9",
        "foregroundImage": "./assets/logo1.png",
        "monochromeImage": "./assets/logo-mono.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "com.rustem_aydin.akillikazanamazirehberi"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/logo1.png"
    },

    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo1.png",
          "color": "#f7faf9"
        }
      ],
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./assets/logo1.png",
          "imageWidth": 200
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "ac72a5b6-e3d6-486d-82c9-a356abff794c"
      }
    }
  }
}
